{
	"name": "frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check .",
		"format": "prettier --write .",
		"db:push": "drizzle-kit push --yes",
		"db:seed-institution": "bun run src/lib/server/db/seeds/seed-institutions.ts",
		"db:seed-avatar": "bun run src/lib/server/db/seeds/seeds-avatar-interviewer.ts",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes"
	},
	"devDependencies": {
		"@better-auth/cli": "^1.4.21",
		"@faker-js/faker": "^10.3.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^22",
		"@types/three": "^0.184.0",
		"@vite-pwa/sveltekit": "^1.1.0",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"postgres": "^3.4.9",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.2",
		"svelte-adapter-bun": "^1.0.1",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"@better-auth/core": "^1.6.9",
		"@lucide/svelte": "^1.3.0",
		"@mediapipe/tasks-vision": "^0.10.34",
		"@paralleldrive/cuid2": "^3.3.0",
		"@sveltejs/enhanced-img": "^0.10.4",
		"better-auth": "^1.6.9",
		"chart.js": "^4.5.1",
		"face-api.js": "^0.22.2",
		"fs": "^0.0.1-security",
		"groq-sdk": "^1.1.2",
		"path": "^0.12.7",
		"svelte-chartjs": "^4.0.1",
		"three": "^0.184.0"
	}
}
